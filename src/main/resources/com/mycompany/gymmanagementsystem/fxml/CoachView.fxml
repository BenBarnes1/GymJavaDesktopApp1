<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="555.0" prefWidth="880.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.gymmanagementsystem.controller.CoachController">
    <children>
        <AnchorPane layoutX="14.0" layoutY="17.0" prefHeight="520.0" prefWidth="283.0" stylesheets="@../style/dashboardDesign.css">
            <styleClass>
                <String fx:value="white-bg" />
                <String fx:value="shadow" />
            </styleClass>
            <children>
                <Label layoutX="61.0" layoutY="37.0" text="Coach ID:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <TextField fx:id="coaches_coachID" layoutX="127.0" layoutY="35.0" prefHeight="26.0" prefWidth="148.0" styleClass="textfield" stylesheets="@../style/dashboardDesign.css" />
            
                <Label layoutX="79.0" layoutY="76.0" text="Name:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <TextField fx:id="coaches_name" layoutX="127.0" layoutY="73.0" prefHeight="25.0" prefWidth="148.0" styleClass="textfield" stylesheets="@../style/dashboardDesign.css" />
            
                <Label layoutX="64.0" layoutY="116.0" text="Address:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <TextArea fx:id="coaches_address" layoutX="127.0" layoutY="109.0" prefHeight="83.0" prefWidth="148.0" styleClass="textfield" stylesheets="@../style/dashboardDesign.css" />
            
                <Label layoutX="56.0" layoutY="262.0" text="Gender:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <ComboBox fx:id="coaches_gender" layoutX="126.0" layoutY="260.0" prefWidth="150.0" promptText="Choose..." styleClass="textfield" stylesheets="@../style/dashboardDesign.css" />
            
                <Label layoutX="22.0" layoutY="205.0" text="Phone Number:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <TextField fx:id="coaches_phoneNum" layoutX="129.0" layoutY="212.0" prefHeight="25.0" prefWidth="148.0" styleClass="textfield" stylesheets="@../style/dashboardDesign.css" />
            
                <Label layoutX="58.0" layoutY="303.0" text="Status:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <ComboBox fx:id="coaches_status" layoutX="126.0" layoutY="301.0" prefWidth="150.0" promptText="Choose..." styleClass="textfield" stylesheets="@../style/dashboardDesign.css" />
            
                <Button fx:id="coaches_addBtn" layoutX="30.0" layoutY="356.0" mnemonicParsing="false" onAction="#coachesAddBtn" prefHeight="45.0" prefWidth="98.0" styleClass="btn" stylesheets="@../style/dashboardDesign.css" text="Add" />
                <Button fx:id="coaches_updateBtn" layoutX="153.0" layoutY="357.0" mnemonicParsing="false" onAction="#coachesUpdateBtn" prefHeight="47.0" prefWidth="93.0" styleClass="btn" stylesheets="@../style/dashboardDesign.css" text="Update" />
                <Button fx:id="coaches_resetBtn" layoutX="31.0" layoutY="440.0" mnemonicParsing="false" onAction="#coachesClearBtn" prefHeight="46.0" prefWidth="97.0" styleClass="btn" stylesheets="@../style/dashboardDesign.css" text="Reset" />
                <Button fx:id="coaches_deleteBtn" layoutX="153.0" layoutY="441.0" mnemonicParsing="false" onAction="#coachesDeleteBtn" prefHeight="46.0" prefWidth="97.0" styleClass="btn" stylesheets="@../style/dashboardDesign.css" text="Delete" />
            </children>
        </AnchorPane>
      
        <AnchorPane layoutX="324.0" layoutY="18.0" prefHeight="520.0" prefWidth="542.0" stylesheets="@../style/dashboardDesign.css">
            <styleClass>
                <String fx:value="white-bg" />
                <String fx:value="shadow" />
            </styleClass>
            <children>
                <TextField fx:id="coaches_search" layoutX="14.0" layoutY="14.0" prefHeight="30.0" prefWidth="250.0" promptText="Search (Name or ID)..." styleClass="textfield" stylesheets="@../style/dashboardDesign.css" />
                <Button fx:id="coaches_searchBtn" layoutX="274.0" layoutY="14.0" mnemonicParsing="false" onAction="#coachesSearchBtn" prefHeight="30.0" prefWidth="80.0" styleClass="btn" stylesheets="@../style/dashboardDesign.css" text="Search" />
                <Button fx:id="coaches_sortBtn" layoutX="364.0" layoutY="14.0" mnemonicParsing="false" onAction="#coachesSortBtn" prefHeight="30.0" prefWidth="80.0" styleClass="btn" stylesheets="@../style/dashboardDesign.css" text="Sort ID" />
            
                <TableView fx:id="coaches_tableView" layoutX="13.0" layoutY="57.0" onMouseClicked="#coachesSelect" prefHeight="446.0" prefWidth="516.0">
                    <columns>
                        <TableColumn fx:id="coaches_col_coachID" prefWidth="66.0" text="Coach ID" />
                        <TableColumn fx:id="coaches_col_name" prefWidth="102.0" text="Name" />
                        <TableColumn fx:id="coaches_col_address" prefWidth="126.0" text="Address" />
                        <TableColumn fx:id="coaches_col_gender" prefWidth="86.0" text="Gender" />
                        <TableColumn fx:id="coaches_col_phoneNum" prefWidth="73.0" text="Phone #" />
                        <TableColumn fx:id="coaches_col_status" prefWidth="62.0" text="Status" />
                    </columns>
                </TableView>
            </children>
        </AnchorPane>
        <Separator layoutX="308.0" layoutY="18.0" orientation="VERTICAL" prefHeight="512.0" prefWidth="8.0" />
    </children>
</AnchorPane>