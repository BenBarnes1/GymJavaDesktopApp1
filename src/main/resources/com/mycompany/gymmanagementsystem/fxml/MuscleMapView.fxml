<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="555.0" prefWidth="880.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.gymmanagementsystem.controller.MuscleMapController">
    <children>
        <AnchorPane layoutX="14.0" layoutY="14.0" prefHeight="527.0" prefWidth="852.0" stylesheets="@../style/dashboardDesign.css">
            <styleClass>
                <String fx:value="white-bg" />
                <String fx:value="shadow" />
            </styleClass>
            <children>
                <Label layoutX="25.0" layoutY="20.0" text="INTERACTIVE MUSCLE MAP">
                    <font>
                        <Font name="Arial Bold" size="24.0" />
                    </font>
                </Label>
                <Label layoutX="25.0" layoutY="50.0" text="Click on a body part to see relevant equipments" textFill="#777777">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>

                <AnchorPane layoutX="25.0" layoutY="80.0" prefHeight="420.0" prefWidth="300.0" style="-fx-border-color: #ddd; -fx-border-radius: 10;">
                    <children>
                        <ImageView fitHeight="400.0" fitWidth="280.0" layoutX="10.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/body.jpg" />
                            </image>
                        </ImageView>

                        <Button fx:id="btn_chest" layoutX="49.0" layoutY="60.0" mnemonicParsing="false" onAction="#muscleMapSelect" prefHeight="36.0" prefWidth="58.0" style="-fx-background-color: #ff0000; -fx-opacity: 0.3; -fx-cursor: hand;" text="CHEST" />
                  
                        <Button fx:id="btn_arm_left" layoutX="14.0" layoutY="56.0" mnemonicParsing="false" onAction="#muscleMapSelect" prefHeight="90.0" prefWidth="36.0" style="-fx-background-color: blue; -fx-opacity: 0.2; -fx-cursor: hand;" text="L-ARM" />
                  
                        <Button fx:id="btn_arm_right" layoutX="107.0" layoutY="56.0" mnemonicParsing="false" onAction="#muscleMapSelect" prefHeight="100.0" prefWidth="36.0" style="-fx-background-color: blue; -fx-opacity: 0.2; -fx-cursor: hand;" text="R-ARM" />
                  
                        <Button fx:id="btn_abs" layoutX="56.0" layoutY="101.0" mnemonicParsing="false" onAction="#muscleMapSelect" prefHeight="47.0" prefWidth="43.0" style="-fx-background-color: green; -fx-opacity: 0.3; -fx-cursor: hand;" text="ABS" />
                  
                        <Button fx:id="btn_legs" layoutX="32.0" layoutY="156.0" mnemonicParsing="false" onAction="#muscleMapSelect" prefHeight="138.0" prefWidth="91.0" style="-fx-background-color: yellow; -fx-opacity: 0.3; -fx-cursor: hand;" text="LEGS" />
                  
                    </children>
                </AnchorPane>

                <AnchorPane layoutX="350.0" layoutY="80.0" prefHeight="420.0" prefWidth="480.0">
                    <children>
                        <Label fx:id="muscleMap_targetLabel" layoutX="10.0" layoutY="10.0" text="Target Area: None" textFill="#850e0e">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <TableView fx:id="muscleMap_tableView" layoutY="50.0" prefHeight="370.0" prefWidth="480.0">
                            <columns>
                                <TableColumn fx:id="muscleMap_col_name" prefWidth="180.0" text="Equipment Name" />
                                <TableColumn fx:id="muscleMap_col_type" prefWidth="150.0" text="Type" />
                                <TableColumn fx:id="muscleMap_col_status" prefWidth="148.0" text="Condition" />
                            </columns>
                        </TableView>
                    </children>
                </AnchorPane>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>