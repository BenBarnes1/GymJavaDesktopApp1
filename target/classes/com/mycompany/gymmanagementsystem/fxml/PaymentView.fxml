<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="555.0" prefWidth="880.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.gymmanagementsystem.controller.PaymentController">
    <children>
        <AnchorPane prefHeight="523.0" prefWidth="543.0" stylesheets="@../style/dashboardDesign.css" AnchorPane.bottomAnchor="16.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="323.0" AnchorPane.topAnchor="16.0">
            <styleClass>
                <String fx:value="white-bg" />
                <String fx:value="shadow" />
            </styleClass>
            <children>
                <TableView fx:id="payment_tableView" layoutX="14.0" layoutY="16.0" prefHeight="492.0" prefWidth="515.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="16.0">
                    <columns>
                        <TableColumn fx:id="payment_col_customerID" prefWidth="107.0" text="Customer ID" />
                        <TableColumn fx:id="payment_col_name" prefWidth="121.0" text="Name" />
                        <TableColumn fx:id="payment_col_startDate" prefWidth="102.0" text="Start Date" />
                        <TableColumn fx:id="payment_col_endDate" prefWidth="81.0" text="End Date" />
                        <TableColumn fx:id="payment_col_status" prefWidth="102.0" text="Status" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </AnchorPane>
      
        <AnchorPane prefHeight="522.0" prefWidth="293.0" stylesheets="@../style/dashboardDesign.css" AnchorPane.bottomAnchor="16.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="17.0">
            <styleClass>
                <String fx:value="white-bg" />
                <String fx:value="shadow" />
            </styleClass>
            <children>
                <Label layoutX="38.0" layoutY="29.0" text="Customer ID:">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Label>
                <ComboBox fx:id="payment_customerID" layoutX="133.0" layoutY="27.0" onAction="#paymentMemberId" prefWidth="150.0" promptText="Choose..." styleClass="textfield" stylesheets="@../style/dashboardDesign.css" />
            
                <Label layoutX="81.0" layoutY="72.0" text="Name:">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Label>
                <ComboBox fx:id="payment_name" layoutX="133.0" layoutY="70.0" onAction="#paymentName" prefWidth="150.0" promptText="Choose..." styleClass="textfield" stylesheets="@../style/dashboardDesign.css" />
            
                <Label layoutX="50.0" layoutY="115.0" text="Price/Day:">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Label>
                <TextField fx:id="payment_pricePerDay" layoutX="133.0" layoutY="113.0" prefHeight="25.0" prefWidth="100.0" styleClass="textfield" stylesheets="@../style/dashboardDesign.css" />
                <Button layoutX="238.0" layoutY="113.0" mnemonicParsing="false" onAction="#saveNewDefaultPrice" prefHeight="25.0" prefWidth="45.0" styleClass="btn" stylesheets="@../style/dashboardDesign.css" text="Set">
                    <font>
                        <Font size="10.0" />
                    </font>
                    <tooltip>
                        <Tooltip text="Set Default" />
                    </tooltip>
                </Button>
            
                <Label layoutX="48.0" layoutY="155.0" text="Discount (%):">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Label>
                <TextField fx:id="payment_discount" layoutX="133.0" layoutY="153.0" prefHeight="25.0" prefWidth="150.0" promptText="0" styleClass="textfield" stylesheets="@../style/dashboardDesign.css" text="0" />
            
                <Label layoutX="89.0" layoutY="205.0" text="Total:">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Label>
                <Label fx:id="payment_total" layoutX="132.0" layoutY="202.0" prefHeight="21.0" prefWidth="152.0" text="0.0 VND">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            
                <Label layoutX="68.0" layoutY="244.0" text="Amount:">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Label>
                <TextField fx:id="payment_amount" layoutX="136.0" layoutY="232.0" onAction="#paymentAmount" styleClass="textfield" stylesheets="@../style/dashboardDesign.css" />
            
                <Label layoutX="69.0" layoutY="285.0" text="Change:">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Label>
                <Label fx:id="payment_change" layoutX="132.0" layoutY="282.0" prefHeight="21.0" prefWidth="152.0" text="0.0 VND">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            
                <Button fx:id="payment_payBtn" layoutX="14.0" layoutY="350.0" mnemonicParsing="false" onAction="#paymentPayBtn" prefHeight="44.0" prefWidth="266.0" styleClass="btn" stylesheets="@../style/dashboardDesign.css" text="Pay" />
            </children>
        </AnchorPane>
    </children>
</AnchorPane>